# 复制本文件为 .env 并填入你自己的高德 Web 服务 API Key
# Copy this file to .env and fill in your own AMAP (Gaode) Web-service API key.
#
# 申请地址 / Apply at: https://console.amap.com/dev/key/app
# 注意：.env 已被 .gitignore 排除，不会上传仓库。

AMAP_KEY=your_amap_web_service_key_here

# 可选：若原始数据不在默认位置（与本项目同级的 data_acquiration），可指定绝对路径
# MENTOUGOU_DATA_DIR=/absolute/path/to/data_acquiration
